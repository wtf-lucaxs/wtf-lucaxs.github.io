<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lucas Daniel - Portfólio Tech</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    /* Reset */
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }

    body { 
        scroll-behavior: smooth; 
        background: #0a0f23; 
        color: #e0e0e0; 
    }

    nav { 
        position: sticky; 
        top: 0; 
        z-index: 1000; 
        background: #0d1321; 
    }

    nav .navbar-brand { font-weight: bold; color: #00f0ff !important; }

    nav .nav-link { color: #a0a0a0 !important; transition: 0.3s; }
    nav .nav-link:hover { color: #00f0ff !important; }

    header {
        background: linear-gradient(135deg, #0d1321, #1e1e3f);
        color: #00f0ff;
        padding: 80px 0;
        text-align: center;
    }
    header h1 { font-size: 3rem; margin-bottom: 15px; letter-spacing: 1px; }
    header p { font-size: 1.2rem; color: #a0f0ff; }

    section { padding: 80px 0; }
    .section-title {
        font-size: 2rem; 
        margin-bottom: 40px; 
        text-align: center; 
        color: #00f0ff;
        position: relative;
    }
    .section-title::after {
        content: '';
        display: block;
        width: 60px;
        height: 3px;
        background: #00f0ff;
        margin: 10px auto 0;
        border-radius: 2px;
    }

    .card {
        background: #1a1f3f;
        color: #e0e0e0;
        border: none;
        border-radius: 12px;
        overflow: hidden;
        transition: transform 0.3s, box-shadow 0.3s;
    }
    .card:hover {
        transform: translateY(-10px);
        box-shadow: 0 10px 25px rgba(0,255,255,0.3);
    }
    .card img { border-bottom: 1px solid #00f0ff; }

    #certificados img {
        max-width: 600px;
        border: 2px solid #00f0ff;
        border-radius: 12px;
    }

    footer { 
        background-color: #0d1321; 
        color: #00f0ff; 
        text-align: center; 
        padding: 30px 0; 
    }

    input, textarea {
        background: #0d1321;
        border: 1px solid #00f0ff;
        color: #e0e0e0;
        border-radius: 8px;
    }
    input::placeholder, textarea::placeholder { color: #a0a0a0; }
    .btn-primary { background-color: #00f0ff; border: none; color: #0d1321; transition: 0.3s; }
    .btn-primary:hover { background-color: #00d0ff; color: #000; }

</style>
</head>
<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
        <a class="navbar-brand" href="#">Lucas Daniel</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link" href="#sobre">Sobre</a></li>
                <li class="nav-item"><a class="nav-link" href="#projetos">Projetos</a></li>
                <li class="nav-item"><a class="nav-link" href="#certificados">Certificados</a></li>
                <li class="nav-item"><a class="nav-link" href="#contato">Contato</a></li>
            </ul>
        </div>
    </div>
</nav>

<!-- Header -->
<header>
    <h1>Lucas Daniel</h1>
    <p>Estudante Técnico em Análise de Sistemas | Desenvolvedor Front-end | Entusiasta de IA</p>
</header>

<!-- Seção Sobre -->
<section id="sobre">
    <div class="container">
        <h2 class="section-title">Sobre Mim</h2>
        <p class="text-center">Sou Lucas Daniel, estudante técnico em Análise de Sistemas no Colégio Kennedy.  
        Tenho experiência em JavaScript, desenvolvimento web e exploração de Inteligência Artificial para soluções criativas e projetos inovadores.</p>
    </div>
</section>

<!-- Seção Projetos -->
<section id="projetos">
    <div class="container">
        <h2 class="section-title">Meus Projetos</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card">
                    <img src="project1.jpg" class="card-img-top" alt="Projeto JavaScript">
                    <div class="card-body">
                        <h5 class="card-title">Projetos em JavaScript</h5>
                        <p class="card-text">Criação de scripts e aplicações web aprendidos nos cursos da Alura.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <img src="project2.jpg" class="card-img-top" alt="Projeto IA">
                    <div class="card-body">
                        <h5 class="card-title">Projetos com IA</h5>
                        <p class="card-text">Exploração de IA Generativa para criação de ideias, imagens e melhoria de código.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <img src="project3.jpg" class="card-img-top" alt="Projetos Técnicos">
                    <div class="card-body">
                        <h5 class="card-title">Projetos Técnicos</h5>
                        <p class="card-text">Desenvolvimento de aplicações e códigos voltados para aprendizado técnico.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Seção Certificados -->
<section id="certificados">
    <div class="container">
        <h2 class="section-title">Certificados</h2>
        <p class="text-center">Certificado de conclusão do curso de Programação na Alura</p>
        <div class="text-center">
            <img src="uploaded-certificado.jpeg" alt="Certificado Alura - Lucas Daniel" class="img-fluid">
        </div>
    </div>
</section>

<!-- Seção Contato -->
<section id="contato">
    <div class="container">
        <h2 class="section-title">Contato</h2>
        <form class="mx-auto" style="max-width: 600px;">
            <div class="mb-3">
                <label for="nome" class="form-label">Nome</label>
                <input type="text" class="form-control" id="nome" placeholder="Seu nome">
            </div>
            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" class="form-control" id="email" placeholder="seu@email.com">
            </div>
            <div class="mb-3">
                <label for="telefone" class="form-label">Telefone</label>
                <input type="tel" class="form-control" id="telefone" value="4299236132">
            </div>
            <div class="mb-3">
                <label for="mensagem" class="form-label">Mensagem</label>
                <textarea class="form-control" id="mensagem" rows="4" placeholder="Escreva sua mensagem"></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-100">Enviar</button>
        </form>
        <p class="text-center mt-3">📞 Contato rápido: (42) 99236-132</p>
    </div>
</section>

<!-- Rodapé -->
<footer>
    &copy; 2026 Lucas Daniel | Contato: (42) 99236-132 | Desenvolvido com Inteligência Artificial
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
